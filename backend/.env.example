# Copiá este archivo como ".env" y completá con tus datos reales

PORT=3010

# Access Token de PRODUCCIÓN de MercadoPago (panel: Tus integraciones > Credenciales de producción)
# ⚠️ NO lo compartas ni lo subas a git. Usá uno FRESCO (reseteá el anterior).
MP_ACCESS_TOKEN=APP_USR-tu-access-token-aca

# URL del frontend (a donde vuelve el comprador después de pagar)
FRONTEND_URL=http://localhost:5500

# URL pública del backend (para el webhook de MP/Talo).
# En local, MP/Talo NO pueden llegar a localhost -> hay que usar un túnel (ngrok). Ver notas.
PUBLIC_URL=http://localhost:3010

# ─── PRECIO Y CARGO POR SERVICIO ───
# Precio de cada entrada (ARS)
PRECIO_ENTRADA=10000
# Cargo por servicio que paga el comprador (%). Se suma ARRIBA del precio de la entrada.
CARGO_PCT=12

# ─── BASE DE DATOS (MySQL / Aiven) ───
# Credenciales del panel de Aiven (Service > Connection information).
DB_HOST=tu-host.aivencloud.com
DB_PORT=3306
DB_USER=avnadmin
DB_PASSWORD=tu-password
DB_NAME=torneo
# Aiven exige SSL (dejar en true). Solo poné false si usás una base local sin SSL.
DB_SSL=true

# ─── SEGURIDAD ───
# En producción poné NODE_ENV=production (deshabilita el endpoint /api/dev)
NODE_ENV=development
# Secreto para FIRMAR los QR (que no se puedan falsificar). Poné una cadena larga y aleatoria.
QR_SECRET=cambiar-por-una-cadena-larga-y-aleatoria
# Token para el escaneo en puerta (lo usa el que valida entradas). Cadena secreta.
SCAN_TOKEN=cambiar-por-otro-token-secreto
# Máximo de entradas por compra
MAX_ENTRADAS=20
